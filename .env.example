# ─── LLM (Google Gemini 1.5 Flash - FREE tier) ─────────────────────────────
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─── Web Search (Tavily - FREE tier: 1,000 searches/month) ──────────────────
# Get yours at: https://app.tavily.com/home
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Application Config ──────────────────────────────────────────────────────
# The user ID for memory storage (can be any string for single-user setup)
USER_ID=default_user

# ─── Google Calendar (OAuth 2.0) ─────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project, enable "Google Calendar API"
# 3. Go to APIs & Services > Credentials > Create OAuth 2.0 Client ID
# 4. Application type: Desktop App
# 5. Download the credentials JSON file and save it as backend/credentials.json
# The token.json will be auto-generated on first run.
